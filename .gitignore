# ------------------------------------------------------------
# System / IDE / Python cache
# ------------------------------------------------------------
.vscode/
__pycache__/
*.pyc
.ipynb_checkpoints/
.DS_Store
Thumbs.db


# ------------------------------------------------------------
# Large media files
# Ignore videos and common large image/movie formats unless explicitly allowed.
# ------------------------------------------------------------
*.mp4
*.mov
*.avi
*.mkv
*.wmv
*.m4v


# ------------------------------------------------------------
# Private project data
# Do not commit animal images, raw source datasets, or study data by default.
# ------------------------------------------------------------
projects/*/data/scored_photos/**
projects/*/data/unscored_photos/**


# ------------------------------------------------------------
# Segmentation annotations
# Ignore real annotation images/masks by default because they may contain
# private study images. Keep manifests/placeholders unless explicitly allowed.
# ------------------------------------------------------------
projects/*/data/segmentation_annotations/images/**
projects/*/data/segmentation_annotations/masks/**


# ------------------------------------------------------------
# Metadata
# Ignore real metadata tables by default because they may contain animal IDs,
# groups, dates, treatments, etc. Add sanitized examples later if desired.
# ------------------------------------------------------------
projects/*/data/metadata/**


# ------------------------------------------------------------
# Generated intermediate files
# ------------------------------------------------------------
projects/*/work/**


# ------------------------------------------------------------
# Generated results
# ------------------------------------------------------------
projects/*/results/**


# ------------------------------------------------------------
# Keep project folder structure
# ------------------------------------------------------------
!projects/*/data/
!projects/*/data/scored_photos/
!projects/*/data/scored_photos/.gitkeep
!projects/*/data/unscored_photos/
!projects/*/data/unscored_photos/.gitkeep

!projects/*/data/metadata/
!projects/*/data/metadata/.gitkeep

!projects/*/data/segmentation_annotations/
!projects/*/data/segmentation_annotations/annotation_manifest.csv
!projects/*/data/segmentation_annotations/images/
!projects/*/data/segmentation_annotations/images/.gitkeep
!projects/*/data/segmentation_annotations/masks/
!projects/*/data/segmentation_annotations/masks/.gitkeep

!projects/*/work/
!projects/*/work/.gitkeep

!projects/*/results/
!projects/*/results/.gitkeep
!projects/*/results/predictions/
!projects/*/results/predictions/.gitkeep
!projects/*/results/gradcam/
!projects/*/results/gradcam/.gitkeep
!projects/*/results/evaluation/
!projects/*/results/evaluation/.gitkeep
!projects/*/results/segmentation_qc/
!projects/*/results/segmentation_qc/.gitkeep
!projects/*/results/metrics/
!projects/*/results/metrics/.gitkeep
!projects/*/results/analysis/
!projects/*/results/analysis/.gitkeep
!projects/*/results/figures/
!projects/*/results/figures/.gitkeep


# ------------------------------------------------------------
# Demo / documentation exceptions
# Only explicitly approved example images should be tracked.
# ------------------------------------------------------------
!projects/SKA31/data/unscored_photos/Photo_score1/
!projects/SKA31/data/unscored_photos/Photo_score1/**

!projects/SKA31/data/unscored_photos/Score_keys/
!projects/SKA31/data/unscored_photos/Score_keys/**


# ------------------------------------------------------------
# Model weights
# Model weights are large; if tracked, use Git LFS.
# Default: ignore all model files except organized scoring model releases.
# ------------------------------------------------------------
models/**
*.pt
*.pth

!models/
!models/scoring/
!models/scoring/**/
!models/scoring/**/*.pt
!models/scoring/**/.gitkeep

# Local archive only; do not publish old v3 checkpoints
models/scoring/v3/**

# Future segmentation model releases can be enabled later when ready.
# !models/segmentation/
# !models/segmentation/**/
# !models/segmentation/**/*.pt
# !models/segmentation/**/.gitkeep